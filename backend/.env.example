# Local development environment — copy this to .env and fill in values
# On EC2 production, all these values come from SSM Parameter Store instead

DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/sprintflow
JWT_SECRET=your-local-dev-jwt-secret-change-this
JWT_ALGORITHM=HS256
JWT_EXPIRY_DAYS=7

# AWS — for local dev use a real AWS profile or IAM user keys
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

S3_ASSETS_BUCKET=sprintflow-assets-dev
SNS_TOPIC_ARN=arn:aws:sns:ap-south-1:123456789:sprintflow-email-notifications
SQS_QUEUE_URL=https://sqs.ap-south-1.amazonaws.com/123456789/sprintflow-celery-queue
SES_SENDER_EMAIL=noreply@yourdomain.com
CLOUDFRONT_DOMAIN=localhost:5173

# Stripe (use Stripe test keys locally)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Lambda
LAMBDA_REFINE_FUNCTION=sprintflow-task-refiner

DEBUG=true
