[Unit]
Description=SprintFlow FastAPI backend
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/sprintflow/backend
ExecStart=/home/ubuntu/sprintflow/venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 8000 --workers 2
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal
SyslogIdentifier=sprintflow-api

# No .env file — all secrets come from SSM
Environment=AWS_REGION=ap-south-1

[Install]
WantedBy=multi-user.target
